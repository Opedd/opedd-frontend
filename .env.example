# Frontend environment variables for Opedd.
# Values prefixed with VITE_ are exposed to the browser at build time.
# Copy to .env.local and fill in actual values.

# Supabase (public anon key only - NEVER put service role here)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public Stripe publishable key (safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry client DSN (safe to expose, used by @sentry/react)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/...

# ── Test-only (.env.test) ──
# Server-side keys required by Playwright fixtures (DO NOT use in browser bundle)
SUPABASE_SERVICE_KEY=your-service-role-key
PLAYWRIGHT_BASE_URL=http://localhost:8080
